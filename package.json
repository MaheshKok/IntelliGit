{
    "name": "intelligit",
    "displayName": "IntelliGit",
    "description": "%extension.description%",
    "version": "0.12.0",
    "publisher": "MaheshKok",
    "icon": "media/intelligit-icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/MaheshKok/IntelliGit"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "SCM Providers"
    ],
    "keywords": [
        "git",
        "intellij",
        "intellij git",
        "pycharm",
        "pycharm git",
        "intelligent git",
        "intelligit",
        "git client",
        "git gui",
        "commit graph",
        "git graph",
        "branch manager",
        "shelf",
        "stash",
        "source control",
        "log",
        "graph",
        "scm"
    ],
    "activationEvents": [
        "workspaceContains:.git",
        "workspaceContains:**/.git/config",
        "onCommand:intelligit.selectRepository",
        "onCommand:intelligit.showGitLog",
        "onCommand:intelligit.openUndocked",
        "onCommand:intelligit.dockWindow",
        "onCommand:intelligit.toggleUndocked",
        "onWebviewPanel:intelligit.undocked",
        "onView:intelligit.commitGraph",
        "onView:intelligit.sidebarGraph",
        "onCommand:intelligit.cloneRepository",
        "onCommand:intelligit.openFolder",
        "onCommand:intelligit.initializeRepository",
        "onCommand:intelligit.publishBranch"
    ],
    "main": "./dist/extension.js",
    "l10n": "./l10n",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "intelligit",
                    "title": "%intelligit%",
                    "icon": "media/intelligit.svg"
                }
            ],
            "panel": [
                {
                    "id": "intelligitPanel",
                    "title": "%intelligit%",
                    "icon": "media/intelligit.svg"
                }
            ]
        },
        "views": {
            "intelligit": [
                {
                    "id": "intelligit.commitPanel",
                    "name": "%view.commit%",
                    "type": "webview"
                },
                {
                    "id": "intelligit.sidebarGraph",
                    "name": "%view.graph%",
                    "type": "webview"
                },
                {
                    "id": "intelligit.mergeConflicts",
                    "name": "%view.mergeConflicts%",
                    "when": "intelligit.hasMergeConflicts"
                },
                {
                    "id": "intelligit.fileCountBadge",
                    "name": "%view.fileCountBadge%",
                    "visibility": "hidden"
                }
            ],
            "intelligitPanel": [
                {
                    "id": "intelligit.commitGraph",
                    "name": "%intelligit%",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "intelligit.showGitLog",
                "title": "%command.showGitLog%",
                "category": "%intelligit%",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.openUndocked",
                "title": "%command.undock%",
                "category": "%intelligit%",
                "icon": "$(multiple-windows)"
            },
            {
                "command": "intelligit.dockWindow",
                "title": "%command.dockIntelliGit%",
                "category": "%intelligit%",
                "icon": "$(layout-sidebar-left)"
            },
            {
                "command": "intelligit.refresh",
                "title": "%command.refresh%",
                "category": "%intelligit%",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.filterByBranch",
                "title": "%command.filterByBranch%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.selectRepository",
                "title": "%command.selectRepository%",
                "category": "%intelligit%",
                "icon": "$(repo)"
            },
            {
                "command": "intelligit.checkout",
                "title": "%command.checkout%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.newBranchFrom",
                "title": "%command.newBranchFrom%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.checkoutAndRebase",
                "title": "%command.checkoutAndRebaseOntoCurrent%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.rebaseCurrentOnto",
                "title": "%command.rebaseCurrentOntoSelected%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.mergeIntoCurrent",
                "title": "%command.mergeIntoCurrent%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.updateBranch",
                "title": "%command.update%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.pushBranch",
                "title": "%command.push%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.renameBranch",
                "title": "%command.rename%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.deleteBranch",
                "title": "%command.delete%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.fileRollback",
                "title": "%command.rollback%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.fileJumpToSource",
                "title": "%command.jumpToSource%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.fileDelete",
                "title": "%command.delete%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.fileShelve",
                "title": "%command.shelveChanges%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.fileShowHistory",
                "title": "%command.showHistory%",
                "category": "%intelligit%"
            },
            {
                "command": "intelligit.compareWithRevision",
                "title": "%command.compareWithRevision%",
                "category": "%intelligit%",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.compareWithBranch",
                "title": "%command.compareWithBranch%",
                "category": "%intelligit%",
                "icon": "$(git-branch)"
            },
            {
                "command": "intelligit.commitFileCompareWithLocal",
                "title": "%command.compareWithLocal%",
                "category": "%intelligit%",
                "icon": "$(diff)"
            },
            {
                "command": "intelligit.commitFileCherryPickChange",
                "title": "%command.cherryPickSelectedChange%",
                "category": "%intelligit%",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.commitFileRevertChange",
                "title": "%command.revertSelectedChange%",
                "category": "%intelligit%",
                "icon": "$(discard)"
            },
            {
                "command": "intelligit.fileRefresh",
                "title": "%command.refresh%",
                "category": "%intelligit%",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.fileRefreshing",
                "title": "%command.refreshing%",
                "category": "%intelligit%",
                "icon": "$(sync~spin)",
                "enablement": "false"
            },
            {
                "command": "intelligit.openMergeConflict",
                "title": "%command.openMergeConflict%",
                "category": "%intelligit%",
                "icon": "$(go-to-file)"
            },
            {
                "command": "intelligit.detectJetBrainsMergeTool",
                "title": "%command.detectJetBrainsMergeTool%",
                "category": "%intelligit%",
                "icon": "$(search)"
            },
            {
                "command": "intelligit.openMergeConflictInJetBrains",
                "title": "%command.openInJetBrainsMergeTool%",
                "category": "%intelligit%",
                "icon": "$(link-external)"
            },
            {
                "command": "intelligit.conflictAcceptYours",
                "title": "%command.acceptYours%",
                "category": "%intelligit%",
                "icon": "$(arrow-left)"
            },
            {
                "command": "intelligit.conflictAcceptTheirs",
                "title": "%command.acceptTheirs%",
                "category": "%intelligit%",
                "icon": "$(arrow-right)"
            },
            {
                "command": "intelligit.mergeConflictsRefresh",
                "title": "%command.refresh%",
                "category": "%intelligit%",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.openConflictSession",
                "title": "%command.openConflictSession%",
                "category": "%intelligit%",
                "icon": "$(diff-multiple)"
            },
            {
                "command": "intelligit.toggleUndocked",
                "title": "%command.toggleUndockedWindow%",
                "category": "%intelligit%",
                "icon": "$(split-horizontal)"
            },
            {
                "command": "intelligit.cloneRepository",
                "title": "%command.cloneRepository%",
                "category": "%intelligit%",
                "icon": "$(repo-clone)"
            },
            {
                "command": "intelligit.openFolder",
                "title": "%command.openFolder%",
                "category": "%intelligit%",
                "icon": "$(folder-opened)"
            },
            {
                "command": "intelligit.initializeRepository",
                "title": "%command.initializeRepository%",
                "category": "%intelligit%",
                "icon": "$(new-folder)"
            },
            {
                "command": "intelligit.publishBranch",
                "title": "%command.publishBranch%",
                "category": "%intelligit%",
                "icon": "$(cloud-upload)"
            }
        ],
        "submenus": [
            {
                "id": "intelligit.editorContext",
                "label": "%intelligit%",
                "icon": "$(git-branch)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "intelligit.editorContext",
                    "when": "resourceScheme == file",
                    "group": "navigation@9"
                }
            ],
            "intelligit.editorContext": [
                {
                    "command": "intelligit.compareWithRevision",
                    "when": "resourceScheme == file",
                    "group": "1_compare@1"
                },
                {
                    "command": "intelligit.compareWithBranch",
                    "when": "resourceScheme == file",
                    "group": "1_compare@2"
                }
            ],
            "view/title": [
                {
                    "command": "intelligit.refresh",
                    "when": "view == intelligit.commitGraph",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.selectRepository",
                    "when": "view == intelligit.commitGraph",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.openUndocked",
                    "when": "view == intelligit.commitGraph",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.mergeConflictsRefresh",
                    "when": "view == intelligit.mergeConflicts",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.openConflictSession",
                    "when": "view == intelligit.mergeConflicts",
                    "group": "navigation@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "intelligit.conflictAcceptYours",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "inline@1"
                },
                {
                    "command": "intelligit.conflictAcceptTheirs",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "inline@2"
                },
                {
                    "command": "intelligit.openMergeConflict",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "navigation@1"
                },
                {
                    "command": "intelligit.openMergeConflictInJetBrains",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "navigation@2"
                },
                {
                    "command": "intelligit.conflictAcceptYours",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "1_actions@1"
                },
                {
                    "command": "intelligit.conflictAcceptTheirs",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "1_actions@2"
                }
            ],
            "webview/context": [
                {
                    "command": "intelligit.fileRollback",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "1_actions@1"
                },
                {
                    "command": "intelligit.fileJumpToSource",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "1_actions@2"
                },
                {
                    "command": "intelligit.fileDelete",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "2_destructive@1"
                },
                {
                    "command": "intelligit.fileShelve",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "2_destructive@2"
                },
                {
                    "command": "intelligit.fileShowHistory",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "3_info@1"
                },
                {
                    "command": "intelligit.fileRefresh",
                    "when": "webviewId == 'intelligit.commitPanel' && !intelligit.commitPanel.refreshing",
                    "group": "3_info@2"
                },
                {
                    "command": "intelligit.fileRefreshing",
                    "when": "webviewId == 'intelligit.commitPanel' && intelligit.commitPanel.refreshing",
                    "group": "3_info@2"
                },
                {
                    "command": "intelligit.commitFileCompareWithLocal",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles' || webviewId == 'intelligit.undocked') && webviewSection == 'commitInfoFile'",
                    "group": "1_compare@1"
                },
                {
                    "command": "intelligit.commitFileCherryPickChange",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles' || webviewId == 'intelligit.undocked') && webviewSection == 'commitInfoFile'",
                    "group": "2_apply@1"
                },
                {
                    "command": "intelligit.commitFileRevertChange",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles' || webviewId == 'intelligit.undocked') && webviewSection == 'commitInfoFile'",
                    "group": "2_apply@2"
                }
            ]
        },
        "keybindings": [
            {
                "command": "intelligit.showGitLog",
                "key": "alt+9",
                "mac": "alt+9"
            }
        ],
        "configuration": {
            "title": "%intelligit%",
            "properties": {
                "intelligit.jetbrainsMergeTool.path": {
                    "type": "string",
                    "default": "",
                    "scope": "machine",
                    "markdownDescription": "%configuration.jetbrainsMergeTool.path.markdownDescription%"
                },
                "intelligit.jetbrainsMergeTool.preferExternal": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "%configuration.jetbrainsMergeTool.preferExternal.markdownDescription%"
                },
                "intelligit.tooltips.enabled": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "%configuration.tooltips.enabled.markdownDescription%"
                },
                "intelligit.undockableWindow": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "%configuration.undockableWindow.markdownDescription%"
                },
                "intelligit.icons": {
                    "type": "string",
                    "enum": [
                        "color",
                        "standard"
                    ],
                    "enumDescriptions": [
                        "%configuration.icons.enum.color%",
                        "%configuration.icons.enum.standard%"
                    ],
                    "default": "standard",
                    "markdownDescription": "%configuration.icons.markdownDescription%"
                },
                "intelligit.commitWindowPosition": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "left",
                        "right"
                    ],
                    "enumDescriptions": [
                        "%configuration.commitWindowPosition.enum.auto%",
                        "%configuration.commitWindowPosition.enum.left%",
                        "%configuration.commitWindowPosition.enum.right%"
                    ],
                    "default": "auto",
                    "markdownDescription": "%configuration.commitWindowPosition.markdownDescription%"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "bun scripts/build.js --production",
        "build": "bun scripts/build.js",
        "build:prod": "bun scripts/build.js --production",
        "watch": "bun scripts/watch.js",
        "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
        "l10n:sync": "bun scripts/localization-csv.js sync",
        "l10n:translate": "bun scripts/localization-csv.js translate",
        "l10n:validate": "bun scripts/localization-csv.js validate",
        "l10n:import": "bun scripts/localization-csv.js import",
        "l10n:audit": "bun scripts/audit-localization-strings.js",
        "lint": "eslint src scripts",
        "lint:strict": "eslint src scripts --max-warnings=0",
        "react-doctor": "react-doctor -y",
        "deps:check": "knip --no-exit-code",
        "deps:check:strict": "knip",
        "architecture:check": "depcruise src --include-only \"^src\" --config .dependency-cruiser.cjs",
        "typecheck:ext": "tsc -p tsconfig.json --noEmit",
        "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
        "typecheck": "bun run typecheck:ext && bun run typecheck:webview",
        "test": "bun vitest run",
        "test:coverage": "bun vitest run --coverage",
        "test:watch": "bun vitest",
        "package": "vsce package --no-dependencies",
        "publish": "vsce publish --no-dependencies"
    },
    "devDependencies": {
        "@chakra-ui/react": "^2.8.2",
        "@emotion/react": "^11.11.3",
        "@emotion/styled": "^11.11.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.11.0",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/vscode": "^1.96.0",
        "@vitest/coverage-v8": "1.6.1",
        "@vscode/vsce": "^2.22.0",
        "dependency-cruiser": "^17.4.3",
        "esbuild": "^0.20.0",
        "eslint": "^10.0.0",
        "eslint-plugin-jsdoc": "^63.0.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-tsdoc": "^0.5.2",
        "framer-motion": "^11.0.0",
        "globals": "^17.3.0",
        "jsdom": "^28.1.0",
        "knip": "^6.15.0",
        "prettier": "^3.8.3",
        "react": "^18.2.0",
        "react-doctor": "^0.2.16",
        "react-dom": "^18.2.0",
        "react-icons": "^5.5.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vitest": "^1.2.0"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1",
        "simple-git": "^3.32.3"
    }
}
